// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  CLIENT
}

model User {
  id        String     @id @default(auto()) @map("_id") @db.ObjectId
  name      String
  email     String     @unique
  password  String
  role      Role       @default(CLIENT)

  userGames WishList[] @relation("Users")
  userComments Comments[] @relation("Users")

  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  @@map("users")
}

model Comments {
  id            String   @id @default(auto()) @map("_id") @db.ObjectId 
  avaliation    Int?     @default(0)
  comment       String[]
  response      String[]

  gameId    String
  game      Game     @relation("Games", fields: [gameId], references: [id])

  userId        String  @db.ObjectId
  user          User    @relation("Users", fields: [userId], references: [id])

  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  @@map("comments")
}

type Assets {
  boxart    String?
  banner200 String?
  banner400 String?
  banner600 String?
}

type Shop {
  id   Int?    
  name String?
}

type Price {
  amount   Float
  currency String
}

type Deal {
  shop          Shop
  price         Price
  regular       Price
  cut           Int?
  voucher       String?
  storeLow      Price?
  historyLow    Price?
  historyLow_1y Price?
  historyLow_3m Price?
}

type Drm {
  id   Int?
  name String?
}

type DeveloperPublisher {
  id   Int?
  name String?
}

type Review {
  score  Int?
  source String?
  count  Int?
  url    String?
}

type PlayerStats {
  recent Int?
  day    Int?
  week   Int?
  peak   Int?
}


model Game {
  id            String   @id @default(auto()) @map("_id") @db.ObjectId
  
  externalApiId String?  @unique 
  title         String
  genre         String?
  assets        Assets?
  deal          Deal?
  flag          String? 
  drm           Drm[]
  timestamp     DateTime?
  expiry        DateTime?
  url           String?

  earlyAccess   Boolean?    
  achievements  Boolean?    
  tradingCards  Boolean?
  tags          String[]
  releaseDate   DateTime? 
  developers    DeveloperPublisher[]
  publishers    DeveloperPublisher[]
  reviews       Review[]
  player        PlayerStats?

  WishList      WishList[] @relation("Games")
  gameComments  Comments[] @relation("Games")

  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  @@map("games")
}

model WishList {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  favorite  Boolean  @default(true)

  gameId    String   @db.ObjectId
  game      Game     @relation("Games", fields: [gameId], references: [id])
  
  userId    String   @db.ObjectId
  user      User     @relation("Users", fields: [userId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, gameId])
  @@map("wishList")
}